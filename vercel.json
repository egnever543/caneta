{
  "rewrites": [
    { "source": "/", "destination": "/landing-page-needle-no-fear.html" },
    { "source": "/pt", "destination": "/landing-page-caneta-sem-medo.html" }
  ],
  "headers": [
    {
      "source": "/public/(.*)",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment" },
        { "key": "Cache-Control", "value": "private, no-cache" }
      ]
    }
  ]
}
